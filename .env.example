# ─────────────────────────────────────────────────────────────────
#  Atlas — Travel Planning & Booking Agent
#  Environment Variables Template
#
#  Copy this file to .env and fill in your actual values.
#  ⚠️  Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# ─── LiveKit Configuration ───────────────────────────────────────
# Get from: https://cloud.livekit.io → Your Project → Settings
LIVEKIT_URL=wss://your-project-name.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxxxxxx
LIVEKIT_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── LLM Configuration ──────────────────────────────────────────
# Atlas picks the first backend that has a key: Anthropic → Groq → Ollama.
#
# Option A: Anthropic Claude (Recommended — pay-as-you-go, no daily token wall)
# Uses claude-haiku-4-5 by default (fast + cheap, ideal for voice).
# Get from: https://console.anthropic.com/settings/keys  (add billing credit)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Speech-to-Text + Text-to-Speech ────────────────────────────
# Deepgram powers BOTH speech-to-text (Nova-2) and text-to-speech
# (Aura-2). A single key covers the whole voice pipeline.
# Get from: https://console.deepgram.com → API Keys
DEEPGRAM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Hotel Search (Booking.com via RapidAPI) ────────────────────
# Powers the `search_accommodations` tool. OPTIONAL — if left blank or invalid,
# Atlas automatically falls back to the curated mock hotels in
# server/data/destinations.json, so the demo still works without it.
#
# How to get a free key (takes ~2 minutes):
#   1. Go to https://rapidapi.com and sign up / log in (free).
#   2. Open the Booking.com API by DataCrawler:
#      https://rapidapi.com/DataCrawler/api/booking-com15
#   3. Click "Subscribe to Test" and choose the free Basic plan.
#   4. On any endpoint page, copy the "X-RapidAPI-Key" value.
#   5. Paste it into RAPIDAPI_KEY below.
# The agent uses the host booking-com15.p.rapidapi.com and the
# searchDestination + searchHotels endpoints. Free tier has a monthly quota;
# the mock fallback covers you if you hit it.
RAPIDAPI_KEY=your_rapidapi_key_here

# ─── Frontend Configuration ─────────────────────────────────────
# URL of your FastAPI token endpoint (used by Next.js client)
NEXT_PUBLIC_LK_TOKEN_ENDPOINT=http://localhost:8000/api/token
